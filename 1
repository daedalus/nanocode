llm:
  default_provider: openrouter
  use_model_registry: true  # Use models.dev for model discovery
  default_model: "z-ai/glm-5.1"  # Free model via OpenCode Zen
  user_agent: "opencode/1.4.8"  # Custom User-Agent for HTTP requests  
  # proxy: http://localhost:8080  # Proxy for HTTP requests
  providers:
    opencode:
      api_key: ${OPENROUTER_API_KEY}  # Use "public" for free models
      base_url: https://openrouter.ai/v1
      model: z-ai/glm-5.1
    
    openai:
      api_key: ${OPENAI_API_KEY}
      base_url: https://api.openai.com/v1
      model: gpt-4o
    
    anthropic:
      api_key: ${ANTHROPIC_API_KEY}
      model: claude-3-5-sonnet-20241022
    
    ollama:
      base_url: http://localhost:11434
      model: llama3
    
    lm-studio:
      base_url: http://localhost:1234/v1
      model: local-model

context:
  strategy: sliding_window  # sliding_window, summary, importance
  max_tokens: 8000
  preserve_system: true
  preserve_last_n: 3
  summarize_threshold: 0.8

mcp:
  servers:
    filesystem:
      url: http://localhost:3000
      enabled: false
    
    git:
      url: http://localhost:3001
      enabled: false

    # Free Exa MCP - no API key required
    exa:
      url: https://mcp.exa.ai/mcp?tools=web_search_exa,deep_search_exa,get_code_context_exa
      enabled: false

    # Open WebSearch MCP - free multi-engine search
    openwebsearch:
      url: https://open-web-search.vercel.app/mcp
      enabled: false

planning:
  max_steps: 20
  max_retries: 3
  checkpoint_enabled: true

tools:
  enabled:
    - bash
    - read
    - write
    - edit
    - glob
    - grep
    - ls
    - webfetch
    - websearch
    - exa          # Paid Exa (requires API key)
    - exa_fetch   # Paid Exa fetch (requires API key)
    - free_exa    # Free Exa (no API key, rate limited)
    - openwebsearch  # Free multi-engine search
    - todo

file_tracker:
  cache_dir: .nanocode/cache
  enabled: true

file_watcher:
  enabled: true
  ignore:
    - .git
    - __pycache__
    - "*.pyc"
    - .pytest_cache
    - node_modules
    - .DS_Store
    - "*.swp"
    - "*.tmp"
    - .venv
    - venv

exa:
  api_key: ${EXA_API_KEY}
  num_results: 10
  default_type: auto

storage:
  enabled: true
  db_path: ~/.nanocode/data/nanocode.db

skills:
  directories:
    - .nanocode/skills
    - .nanocode/commands

snapshot:
  enabled: true
  prune_days: 7

admin:
  enabled: true
  host: 127.0.0.1
  port: 7890

messaging:
  enabled: false
  platforms:
    slack:
      enabled: false
      bot_token: ${SLACK_BOT_TOKEN}
      signing_secret: ${SLACK_SIGNING_SECRET}
      app_token: ${SLACK_APP_TOKEN}
      socket_mode: true
    
    telegram:
      enabled: false
      bot_token: ${TELEGRAM_BOT_TOKEN}
    
    whatsapp:
      enabled: false
      phone_number_id: ${WHATSAPP_PHONE_NUMBER_ID}
      access_token: ${WHATSAPP_ACCESS_TOKEN}
      verify_token: ${WHATSAPP_VERIFY_TOKEN}
      webhook_port: 8080

